{
  "name": "backend",
  "version": "0.1.0",
  "description": "A RESTful API built with icmern",
  "author": "",
  "private": true,
  "type": "module",
  "main": "server.js",
  "imports": {
    "#utils/*": "./src/utils/*",
    "#templates/*": "./src/templates/*",
    "#permissions/*": "./src/permissions/*",
    "#config/*": "./src/config/*",
    "#controllers/*": "./src/controllers/*",
    "#services/*": "./src/services/*",
    "#models/*": "./src/models/*",
    "#middlewares/*": "./src/middlewares/*",
    "#validations/*": "./src/validations/*",
    "#routes/*": "./src/routes/*"
  },
  "scripts": {
    "seed:roles": "node scripts/seed-roles.js",
    "seed:admin": "node scripts/seed-admin.js",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/__tests__/unit",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.5",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.1",
    "eslint": "^9.17.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "vitest": "^4.1.1"
  }
}
